{
  "$schema": "https://moonlight-mod.github.io/manifest.schema.json",
  "id": "bigUpload",
  "version": "1.0.0",
  "apiLevel": 2,
  "meta": {
    "name": "Big Upload",
    "tagline": "Send large files withut nitro!",
    "description": "Send large files without nitro, using services like catbox.moe",
    "tags": ["chat","qol"],
    "authors": ["lare"],
    "source": "https://github.com/lare354/moonlight-plugins"
  },
  "dependencies": ["spacepack","common","commands"],
  "settings": {
    "autosend": {
      "displayName": "Autosend",
      "type": "boolean",
      "default": false,
      "advice": "reload"
    },
    "uploadService": {
      "displayName": "Upload service",
      "type": "select",
      "options": [
        "Catbox", 
        "Litterbox", 
        "Gofile"
      ],
      "default": "Catbox",
      "advice": "reload"
    } 
  }
}
